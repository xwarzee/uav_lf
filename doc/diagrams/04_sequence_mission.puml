@startuml 04_sequence_mission
skinparam sequenceArrowThickness 1.5
skinparam sequenceParticipantBackgroundColor #E3F2FD
skinparam sequenceParticipantBorderColor #1565C0
skinparam sequenceLifeLineBorderColor #90CAF9
skinparam sequenceGroupBackgroundColor #F3E5F5
skinparam backgroundColor #FFFFFF
skinparam defaultFontName Helvetica
skinparam noteBorderColor #F57F17
skinparam noteBackgroundColor #FFF9C4

title DroneSwarm — Scenario: target, formation, mission start, propulsion and obstacle avoidance

participant "Operator\n(stdin)" as OP
participant "MissionCommandInterface" as CI
participant "MissionExecutor\n(coordinator, drone_id=0)" as MC
participant "FormationController\n(leader, drone_id=0)" as SF
participant "DroneNode[i]\n(bank member)" as DN
participant "PositionAggregator" as PA
participant "SwarmVisualizer\n(http://localhost:8080)" as VIZ
participant "ObstacleDetector\n(drone_i)" as OD

== Initialisation (startup) ==

MC  -> MC  : startup → mission_status[N] = "INITIALIZED"\nbroadcast to all drones
SF  -> SF  : startup → formation initialised\nleader_pos = {0, 0, 10}
OD  -> OD  : startup → obstacle list cleared
DN  -> DN  : initial state: x=i×15 m, y=0, z=10 m\ntarget_pos={i×15, 0, 10}
VIZ -> VIZ : startup → HTTP server on :8080\naccept thread started

== Phase 1: Target positioning and formation selection ==

OP  -> CI  : "TARGET 100 50 15"
CI  -> SF  : target_position = {100, 50, 15}
SF  -> SF  : reaction(leader_position)\n→ leader_pos ← {100, 50, 15}

OP  -> CI  : "FORMATION 3  (circle)"
CI  -> SF  : formation_change = 3
SF  -> SF  : current_formation ← 3 (Circle)

note over SF : leader_pos = {100, 50, 15}\nformation = Circle, spacing = 10 m\nDrone 1 target: (110, 50, 15)\nDrone 2 target: (100, 60, 15)\nDrone 3 target:  (90, 50, 15)\nDrone 4 target: (100, 40, 15)

== Phase 1b: Dynamic swarm resizing ==

OP  -> CI  : "SWARM 3"
CI  -> SF  : swarm_size = 3
CI  -> MC  : swarm_size = 3
CI  -> PA  : swarm_size = 3 (active_count)
SF  -> SF  : num_followers ← 3
MC  -> MC  : swarm_size_change reaction\n→ mission_status[3] = "DEACTIVATE"\n[INFO] "Drone 4: removed from swarm"
PA  -> PA  : n_active ← 3\n(drone 4 filtered from position map)
MC  ->> DN : mission_status[3] = "DEACTIVATE"
DN  -> DN  : (drone 4 only)\nactive ← false, mission_active ← false\n[INFO] "Drone 4: removed from swarm"

note over DN : Drone 4 publishes no position\nand applies no propulsion.\nSWARM 4 would reactivate it.

== Phase 2: Formation computation (before START) ==

loop every 50 ms
    SF  -> SF  : formation_timer\n→ for i in 0..N-1:\n    position_command[i] = leader_pos + circleOffsetFor(i+1, N)
    SF  ->> DN : position_command[N]\n{x_formation_i, y_formation_i, z}
    DN  -> DN  : reaction(formation_command)\n→ target_pos ← cmd
end

note over DN : mission_active = false\ndrone remains stationary\n(no propulsion)

== Phase 3: Mission start ==

OP  -> CI  : "SURVEILLANCE"
CI  -> MC  : mission_command = "SURVEILLANCE"
MC  -> MC  : setMissionType("SURVEILLANCE")

OP  -> CI  : "START"
CI  -> MC  : mission_command = "START"
MC  -> MC  : startMission()
MC  -> MC  : [INFO] "Swarm mission 'SURVEILLANCE' starting"
MC  ->> DN : mission_status[N] = "START"

DN  -> DN  : reaction(mission_update="START")\n→ mission_active = true\n[INFO] "Drone i: Mission started — position (x, y, z)"

== Phase 4: Propulsion towards formation ==

loop every 100 ms (mission_active = true)
    DN  -> DN  : update_timer\n— P-controller towards target_pos:\n  speed = min(0.8 × dist, 5 m/s)\n  velocity = speed × dir + avoidance_force\n  x, y, z += velocity × 0.1 s
    DN  ->> PA : position: {x, y, z}
    DN  ->> VIZ : position: {x, y, z}
end

loop every 50 ms
    PA  -> PA  : aggregate_timer\n→ map<drone_id, position>
    PA  -->> DN : aggregated_positions[N]\n(after 10 ms)
    DN  -> DN  : reaction(neighbor_positions)\n→ avoidance_force ← Σ repulsions\n  (2/d² if 0.1 m < d < 5 m)
end

loop every 100 ms
    VIZ -> VIZ : reaction(positions)\n→ JSON SSE broadcast\n  data: {"drones":[{"id":i,"x":...},...]}
end

note over DN, VIZ : Drones converge towards\ntheir formation positions\naround (100, 50, 15).\nThe browser page displays\ntrajectories in 3-D in real time.

== Phase 5: Obstacle detection ==

note over OD : sensor_data received\n(distance = 8 m < threshold 15 m)
OD  -> OD  : reaction(sensor_data)\n→ threat_level = 2 (DANGER)
OD  --> DN : threat_alert = true
OD  -> OD  : [WARN] "THREAT DETECTED at 8 m"

DN  -> MC  : (via mission.obstacle_alert)
MC  -> MC  : reaction(obstacle_alert)\n→ pauseMission()
MC  ->> DN : mission_status[N] = "PAUSED"
DN  -> DN  : mission_active stays true\nbut target_pos frozen

== Phase 6: Resume after clearance ==

note over OD : obstacle gone
OD  -> OD  : avoidance_active = false, threat_level = 0
OD  --> DN : threat_alert = false
OD  -> OD  : [INFO] "Threat cleared"

OP  -> CI  : "RESUME"
CI  -> MC  : mission_command = "RESUME"
MC  -> MC  : resumeMission()
MC  ->> DN : mission_status[N] = "ACTIVE"

== Phase 7: In-flight formation displacement ==

OP  -> CI  : "TARGET 200 100 20"
CI  -> SF  : target_position = {200, 100, 20}
SF  -> SF  : leader_pos ← {200, 100, 20}
SF  ->> DN : new formation positions\naround (200, 100, 20)
DN  -> DN  : target_pos updated\npropulsion replanned

== Phase 8: Mission end / RTB ==

MC  -> MC  : completeMission()
MC  -> MC  : initializeRTBMission()\nhome_base = {0, 0, 10}
MC  ->> DN : mission_status[N] = "RTB"

DN  -> DN  : target_pos ← updated via formation_command\n(or direct command)
DN  -> DN  : propulsion towards base {0, 0, 10}

@enduml
