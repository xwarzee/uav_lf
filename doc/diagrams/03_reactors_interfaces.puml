@startuml 03_reactors_interfaces
skinparam classBackgroundColor #F0F4FF
skinparam classBorderColor #3355AA
skinparam classHeaderBackgroundColor #C5CAE9
skinparam backgroundColor #FFFFFF
skinparam defaultFontName Helvetica
skinparam class {
    FontSize 10
}

title Reactor Interfaces — Ports, Parameters and Timers

class "MissionCommandInterface" <<reactor>> {
    ' Detached thread: reads stdin, schedules physical action
    ..Outputs..
    + mission_command : string
    + formation_change : int
    + target_position : vector<double>
    + swarm_size : int
    ..Commands..
    ~ PATROL  ESCORT  RECONNAISSANCE
    ~ SEARCH_RESCUE  SURVEILLANCE  INTERCEPT
    ~ START  STOP  ABORT  PAUSE  RESUME  RTB
    ~ FORMATION 0..3
    ~ TARGET x y z
    ~ SWARM N
}

class "PositionAggregator" <<reactor>> {
    ' Parameters
    + num_drones : int = 4
    ..Inputs..
    + positions[num_drones] : vector<double>
    + active_count : int
    ..Outputs..
    + aggregated_positions[num_drones] : map<int, vector<double>>
    ..State..
    ~ n_active : int
    ..Timers..
    ~ aggregate_timer : 0, 50 ms
}

class "DroneNode" <<reactor / bank>> {
    ' Parameters
    + bank_index : int = 0  «auto»
    + num_drones : int = 4
    + initial_z : double = 10.0
    ..Inputs..
    + formation_command : vector<double>
    + mission_update : string
    + neighbor_positions : map<int, vector<double>>
    ..Outputs..
    + position : vector<double>
    + status : string
    + threat_detected : bool
    ..State..
    ~ drone_id = bank_index + 1
    ~ x = bank_index*15, y=0, z=initial_z
    ~ target_pos : vector<double>
    ~ avoidance_force : vector<double>
    ~ velocity : vector<double>
    ~ mission_active : bool
    ~ active : bool = true
    ~ mission_was_active : bool = false
    ~ handles: ACTIVATE / DEACTIVATE
    ..Timers..
    ~ update_timer : 0, 100 ms
}

class "FormationController" <<reactor>> {
    ' Parameters
    + drone_id : int = 0
    + formation_type : int = 0
    + swarm_size : int = 4
    ..Inputs..
    + leader_position : vector<double>
    + formation_change : int
    + swarm_size_update : int
    ..Outputs..
    + position_command[swarm_size] : vector<double>
    + formation_status : string
    ..State..
    ~ current_formation, leader_pos = {0,0,10}
    ~ formation_spacing = 10.0 m
    ..Position computation (send_formation_pos)..
    ~ for i in 0..N-1:
    ~   position_command[i] =
    ~     leader_pos + offsetFor(i+1, N)
    ..Formation types..
    ~ 0 = Diamond  1 = Line
    ~ 2 = V-Formation  3 = Circle
    ..Timers..
    ~ formation_timer : 100 ms, 50 ms
}

class "ObstacleDetector" <<reactor>> {
    ' Parameters
    + drone_id : int = 0
    + detection_range : double = 50.0
    + threat_threshold : double = 15.0
    ..Inputs..
    + sensor_data : vector<double>
    + drone_position : vector<double>
    + neighbor_positions : map<int, vector<double>>
    ..Outputs..
    + threat_alert : bool
    + avoidance_vector : vector<double>
    + obstacle_map : vector<vector<double>>
    ..Threat levels..
    ~ 0=safe  1=caution
    ~ 2=danger  3=critical
    ..Timers..
    ~ obstacle_timer : 0, 25 ms  «40 Hz»
}

class "MissionExecutor" <<reactor>> {
    ' Parameters
    + drone_id : int = 0
    + swarm_size : int = 1
    ..Inputs..
    + mission_command : string
    + waypoint_data : vector<vector<double>>
    + drone_status : map<string, double>
    + obstacle_alert : bool
    + formation_ready : bool
    + swarm_size_update : int
    ..Outputs..
    + mission_status[swarm_size] : string
    + target_waypoint : vector<double>
    + mission_complete : bool
    + emergency_abort : bool
    ..mission_status values..
    ~ "INITIALIZED"  "START"  "STOP"
    ~ "PATROL"  "RTB"  ...
    ~ "PATROL_PROGRESS_xx%"
    ~ "ACTIVATE"  "DEACTIVATE"
    ..Supported missions..
    ~ PATROL  ESCORT  RECONNAISSANCE
    ~ SEARCH_RESCUE  CARGO_DELIVERY
    ~ SURVEILLANCE  INTERCEPT  RTB
    ..Timers..
    ~ mission_update_timer : 100 ms, 100 ms
    ~ health_check_timer : 0, 1 s
}

class "DroneComms" <<reactor>> {
    ' Parameters
    + drone_id : int = 0
    + communication_range : double = 100.0
    + encryption_enabled : bool = true
    ..Inputs..
    + outgoing_message : map<string, string>
    + position_update : vector<double>
    + status_update : map<string, double>
    + emergency_signal : string
    + mesh_discovery : vector<int>
    ..Outputs..
    + incoming_message : map<string, string>
    + neighbor_positions : map<int, vector<double>>
    + network_status : string
    + swarm_health : map<int, double>
    ..Timers..
    ~ broadcast_timer : 0, 500 ms
    ~ heartbeat_timer : 0, 1 s
    ~ mesh_update_timer : 0, 2 s
    ~ discovery_timer : 0, 5 s
    ~ cleanup_timer : 0, 10 s
}

class "SwarmVisualizer" <<reactor>> {
    ' Embedded HTTP+SSE server (POSIX sockets)
    ' HTML page in swarm_viz_html.hh
    ' Parameters
    + num_drones : int = 4
    + port : int = 8080
    ..Inputs..
    + positions[num_drones] : vector<double>
    ..HTTP endpoints..
    ~ GET /        -> Three.js page
    ~ GET /events  -> SSE JSON stream
    ..SSE format..
    ~ data: {"drones":[
    ~   {"id":1,"x":10.0,"y":0.0,"z":10.0},
    ~   ...]}
    ..Three.js features..
    ~ 3D quadcopter models per drone
    ~   (body, arms, rotors, legs, LEDs)
    ~ banking + propeller spin animation
    ~ trails (150 positions)
    ~ live coordinate HUD
    ~ OrbitControls
    ..Audio..
    ~ Web Audio API: rotor sound per drone
    ~ SOUND ON/OFF toggle button
}

' Composition inside DroneNode
DroneNode *-- FormationController : formation
DroneNode *-- ObstacleDetector   : obstacle
DroneNode *-- MissionExecutor    : mission
DroneNode *-- DroneComms         : droneComms

' DroneSwarm-level connections
MissionCommandInterface ..> MissionExecutor    : mission_command\nswarm_size → swarm_size_update
MissionCommandInterface ..> FormationController : formation_change\ntarget_position\nswarm_size → swarm_size_update
MissionCommandInterface ..> PositionAggregator : swarm_size → active_count
FormationController     ..> DroneNode          : position_command[N]
MissionExecutor         ..> DroneNode          : mission_status[N]
DroneNode               ..> PositionAggregator : position[N]
PositionAggregator      ..> DroneNode          : aggregated_positions[N]\n(after 10 ms)
DroneNode               ..> SwarmVisualizer    : position[N] (fan-out)

@enduml
