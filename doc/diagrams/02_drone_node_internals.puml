package "DroneNode  В«bank memberВ»" {

    component "FormationController\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\ndrone_id = i+1\nswarm_size = N\nВ«timer 50 msВ»" as FC

    component "ObstacleDetector\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\ndrone_id = i+1\ndetection_range = 50 m\nthreat_threshold = 15 m\nВ«timer 25 ms  (40 Hz)В»" as OD

    component "MissionExecutor\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\ndrone_id = i+1\nswarm_size = 1\nmissions: PATROL, ESCORTвЂ¦\nВ«timer 100 ms + 1 s healthВ»" as ME

    component "DroneComms\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\ndrone_id = i+1\nrange = 100 m\nencryption = true\nВ«timers: 500 ms / 1 s / 2 s / 5 s / 10 sВ»" as DC

    component "Internal State\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nx = iГ—15, y=0, z=10  (initial)\ntarget_pos : vector<double>\navoidance_force : vector<double>\nvelocity : vector<double>\nmission_active : bool\ndrone_id : int" as STATE

