@startuml 01_system_overview
skinparam componentStyle rectangle
skinparam backgroundColor #FFFFFF
skinparam defaultFontName Helvetica
skinparam component {
    BackgroundColor #DDEEFF
    BorderColor #336699
    FontSize 11
}
skinparam package {
    BackgroundColor #F8F8FF
    BorderColor #6688AA
}
skinparam arrow {
    Color #336699
    FontSize 10
    FontColor #444444
}

title DroneSwarm — System Overview\n«Lingua-Franca C++ target»

package "DroneSwarm  «main reactor»  (num_drones=N, log_level=3)" {

    component "MissionCommandInterface\n──────────────\nstdin → physical action\n«detached thread»\noutputs: mission_command\n         formation_change\n         target_position\n         swarm_size" as CI

    component "FormationController\n──────────────\ndrone_id = 0  (leader)\nswarm_size = N\ninput  leader_position\noutput[N] position_command\n«formation timer 50 ms»" as SF

    component "MissionExecutor\n──────────────\ndrone_id = 0  (coordinator)\nswarm_size = N\ninput  swarm_size_update\noutput[N] mission_status\n«update timer 100 ms»" as MC

    component "PositionAggregator\n──────────────\nnum_drones = N\ninput[N] positions\ninput  active_count\noutput[N] aggregated_positions\n«aggregate timer 50 ms»" as PA

    component "SwarmVisualizer\n──────────────\nnum_drones = N\nport = 8080\ninput[N] positions\nHTTP + SSE server\nhttp://localhost:8080" as VIZ

    package "DroneNode[N]  «bank»  bank_index = 0 .. N-1" {
        component "DroneNode\n──────────────\ndrone_id = bank_index + 1\nx₀ = bank_index × 15 m\ntarget_pos, avoidance_force\n«P-controller 100 ms»" as DN
    }
}

CI -down-> MC  : mission_command\nstring
CI -down-> SF  : formation_change\nint
CI -down-> SF  : target_position\nvector<double>\n→ leader_position\n(formation centre)
CI -down-> MC  : swarm_size\nint → swarm_size_update\n(active drone count)
CI -down-> SF  : swarm_size\nint → swarm_size_update
CI -down-> PA  : swarm_size\nint → active_count

SF -down-> DN  : «N → N multiport»\nposition_command[i] : vector<double>\n→ drone i target_pos

MC -down-> DN  : «N → N multiport»\nmission_status[i] : string\n(«START» / «STOP» / type)

DN -right-> PA : «N → N multiport»\nposition[i] : vector<double>

PA -left-> DN  : «N → N multiport, after 10 ms»\naggregated_positions[i] : map<int,vector<double>>

DN -down-> VIZ : «N → N multiport, fan-out»\nposition[i] : vector<double>

note bottom of DN
  Propulsion (mission_active):
    velocity = P-ctrl(target_pos) + avoidance_force
    x, y, z += velocity × 0.1 s
end note

note bottom of VIZ
  Browser: http://localhost:8080
  SSE JSON every 100 ms
  Three.js: quadcopter 3D models + trails + HUD\n  Web Audio API: rotor sound per drone
end note

@enduml
